{
  "type": "object",
  "properties": {
    "products": {
      "type": "array",
      "title": "Товары",
      "format": "table",
      "items": {
        "type": "object",
        "title": "Товар",
        "properties": {
          "id": {
            "type": "integer",
            "title": "ID"
          },
          "name": {
            "type": "string",
            "title": "Название"
          },
          "price": {
            "type": "integer",
            "title": "Цена (₽)",
            "description": "Только цифры"
          },
          "visible": {
            "type": "boolean",
            "title": "Показывать",
            "default": true
          },
          "description": {
            "type": "string",
            "title": "Описание",
            "format": "textarea"
          },
          "image": {
            "type": "string",
            "title": "Путь к картинке",
            "description": "например images/product1.jpeg"
          },
          "category": {
            "type": "string",
            "title": "Категория",
            "enum": ["napkins", "tablecloths", "other"],
            "enum_titles": ["Салфетки", "Скатерти", "Прочее"]
          }
        },
        "required": ["id", "name", "price"]
      }
    }
  }
}